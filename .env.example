# =============================================================================
# Visor360 — variáveis de ambiente
# =============================================================================
# IMPORTANTE: tudo que começa com VITE_ é EMBUTIDO no bundle do frontend e
# fica VISÍVEL pra qualquer pessoa que abrir o DevTools. NUNCA coloque aqui:
#   - chaves privadas, service-role keys, segredos JWT
#   - senhas de banco, credenciais SMTP, tokens de API com permissão de write
# Use SOMENTE chaves públicas/anon que já são desenhadas pra ficar no client.
# =============================================================================

# --- API Quality Automação (read-only) ---
# URL base da API
VITE_API_BASE_URL=https://web.qualityautomacao.com.br/INTEGRACAO

# Chave de integração (parâmetro CHAVE na URL). É a credencial de leitura
# da unidade — escopo limitado ao que o GET expõe na API do Quality.
VITE_API_KEY=

# --- Supabase Auth ---
# Pegue em supabase.com/dashboard → Project Settings → API
# Use APENAS a anon/public key — NUNCA a service_role aqui.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
