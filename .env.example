# URL base da API Quality Automação
VITE_API_BASE_URL=https://web.qualityautomacao.com.br/INTEGRACAO

# Chave de integração da API Quality (parâmetro CHAVE)
VITE_API_KEY=

# --- Supabase Auth (gerente) ---
# Pegue em supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Legacy / fallback (vai sair quando Supabase Auth cobrir todos os fluxos) ---
# Usado como fallback de nome/email na UI quando Supabase Auth não está configurado
# e pelo fluxo Frentista (test access). Em prod com Supabase ativo, pode ser ignorado.
VITE_APP_USER=admin
VITE_APP_PASSWORD=admin
